# ============================================
# AI Sale Agent — Environment Variables
# ============================================
# Скопируйте этот файл: cp .env.example .env
# и заполните значения

# --- LLM Provider ---
# auto     — OpenAI (VPN), при ошибке → GigaChat (без VPN)
# openai   — только OpenAI
# gigachat — только GigaChat
LLM_PROVIDER=auto

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Голос (Whisper + TTS), голос: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# --- GigaChat (Sber) ---
# Получите ключ: https://developers.sber.ru/studio/workspaces/my-space/get/gigachat-api
# 1. Зарегистрируйтесь через Сбер ID
# 2. Создайте проект GigaChat API
# 3. Сгенерируйте Authorization Key
GIGACHAT_CREDENTIALS=your-gigachat-auth-key
GIGACHAT_MODEL=GigaChat
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=false

# --- RAG (ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=ai_sale_knowledge
# RAG_TOP_K=12
# RAG_SCORE_THRESHOLD=0.22
# RAG_FALLBACK_MIN_SCORE=0.12
# RAG_CACHE_ENABLED=true
# RAG_CACHE_TTL_SECONDS=600
# RAG_CACHE_MAX_ITEMS=500
# RESPONSE_CACHE_ENABLED=true
# RESPONSE_CACHE_TTL_SECONDS=300
# RESPONSE_CACHE_MAX_ITEMS=500

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO

# --- Frontend ---
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws/chat

# --- Telegram Bot (уведомления о заявках) ---
# 1. Создайте бота: @BotFather → /newbot → скопируйте токен
# 2. Узнайте chat_id: отправьте боту сообщение, затем откройте
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    и найдите "chat":{"id": XXXXXXX}
# 3. Для группового чата: добавьте бота в группу, chat_id будет отрицательным
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=true

# --- Google Sheets (логирование в таблицу) ---
# 1. Создайте Service Account в Google Cloud Console
# 2. Включите Google Sheets API и Google Drive API
# 3. Скачайте JSON-ключ Service Account
# 4. Создайте Google-таблицу и расшарьте на email Service Account (Редактор)
# 5. Скопируйте ID таблицы из URL
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google_service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Company Settings ---
COMPANY_NAME=ГК Проект
COMPANY_DESCRIPTION=AI-ассистент по инженерным системам
# Свой системный промпт (файл UTF-8 внутри контейнера backend). Пусто = встроенный из app/prompts/system.py
# В шаблоне обязательны ровно два плейсхолдера: {company_name} и {rag_context} (остальные { } — как {{ и }}
# Docker: положите файл в docs/ и укажите путь:
# SYSTEM_PROMPT_PATH=/app/docs/SYSTEM_PROMPT.md
SYSTEM_PROMPT_PATH=
